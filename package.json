{
	"name": "fabma",
	"version": "0.3.0",
	"description": "AI-native design playground — brief in, art directions out. Pick, comment, refine. Export HTML, SVG, or Elementor templates.",
	"license": "MIT",
	"type": "module",
	"main": "desktop/main.js",
	"bin": {
		"fabma": "bin/fabma.js"
	},
	"scripts": {
		"app": "electron .",
		"start": "node bin/fabma.js",
		"dev": "FABMA_WORKSPACE=./workspace FABMA_NO_OPEN=1 node bin/fabma.js",
		"smoke": "node scripts/smoke.js",
		"dist": "electron-builder --mac"
	},
	"engines": {
		"node": ">=18"
	},
	"build": {
		"appId": "dev.fabma.app",
		"productName": "Fabma",
		"directories": {
			"output": "dist"
		},
		"files": [
			"desktop/**/*",
			"server/**/*",
			"web/**/*",
			"bin/**/*",
			"AGENT.md",
			"!desktop/icon.iconset"
		],
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": ["arm64"]
				}
			],
			"category": "public.app-category.graphics-design",
			"icon": "desktop/icon.icns"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/knapcio/fabma.git"
	},
	"keywords": [
		"ai",
		"design",
		"figma",
		"elementor",
		"claude",
		"codex",
		"generative-design",
		"playground",
		"local-first"
	],
	"dependencies": {
		"express": "^5.1.0",
		"node-html-parser": "^7.0.1"
	},
	"devDependencies": {
		"electron": "^36.0.0",
		"electron-builder": "^26.0.0"
	}
}
